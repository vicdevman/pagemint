# Monad Testnet RPC endpoint
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz/

# Wallet Connect ID for RainbowKit (Get one at https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLET_CONNECT_ID=your_wallet_connect_project_id

# Deployed MonadPageMinter Contract Address
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Groq API Key for the AI builder (Get one at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key
